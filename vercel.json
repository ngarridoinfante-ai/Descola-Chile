{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "descolachile.com"
        }
      ],
      "destination": "https://www.descolachile.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/success", "destination": "/success.html" },
    { "source": "/meus-descontos", "destination": "/meus-descontos.html" },
    { "source": "/cupom/:id", "destination": "/cupom.html" },
    { "source": "/apresentar-cupom", "destination": "/apresentar-cupom.html" },
    { "source": "/ajuda", "destination": "/ajuda.html" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/clientes", "destination": "/admin/clientes.html" },
    { "source": "/admin/cupons", "destination": "/admin/cupons.html" },
    { "source": "/admin/partners", "destination": "/admin/partners.html" },
    { "source": "/admin/metricas", "destination": "/admin/metricas.html" },
    { "source": "/admin/configuracoes", "destination": "/admin/configuracoes.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
